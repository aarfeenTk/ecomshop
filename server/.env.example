# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ============================================
# Database Configuration
# ============================================
MONGO_URI=mongodb://localhost:27017/mern-ecommerce

# For production MongoDB (optional)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Change this to a strong random string in production (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_ACCESS_EXPIRE=15m

# ============================================
# CORS Configuration
# ============================================
CLIENT_URL=http://localhost:5173

# For production:
# CLIENT_URL=https://yourdomain.com

# ============================================
# Rate Limiting (optional)
# ============================================
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Production Checklist
# ============================================
# 1. Set NODE_ENV=production
# 2. Generate strong JWT_SECRET (min 32 characters)
# 3. Set proper MONGO_URI for production database
# 4. Set CLIENT_URL to your production domain
# 5. Set LOG_LEVEL=warn or LOG_LEVEL=error
# 6. Enable HTTPS
# 7. Configure reverse proxy (nginx/Apache)
# 8. Set up process manager (PM2)
# 9. Enable log rotation
# 10. Set up monitoring and alerts
